# Copy this file to .env.local and fill in values for local dev.
# In production, set the same vars under Vercel Project → Settings → Environment Variables.
# .env.local is gitignored — never commit a real key.

# Metals.dev — paid pricing provider. Optional. When set, becomes the primary
# source for copper + aluminum live pricing; the Yahoo Finance fallback path
# stays in place if the key is missing or the call fails (quota, schema drift).
# Get a key at https://metals.dev/dashboard. Free tier ≈ 100 req/month —
# fetchMetalsDev() uses revalidate: 1800 (30 min) to stay within budget.
METALS_DEV_API_KEY=

# Production base URL — flows into sitemap.xml, canonical tags, and JSON-LD.
# Defaults to a placeholder when unset; set in Vercel for production.
# NEXT_PUBLIC_SITE_URL=https://whatsmyscrapworth.com
